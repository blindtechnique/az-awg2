[Unit]
Description=AntiZapret-AWG stats collector (one poll)
After=awg-quick@antizapret.service

[Service]
Type=oneshot
Environment=AWG_STATS_DB=/opt/antizapret-awg/stats.db
Environment=AWG_DIR=/etc/amnezia/amneziawg
ExecStart=/opt/antizapret-awg/venv/bin/python /opt/antizapret-awg/awg_stats.py poll
